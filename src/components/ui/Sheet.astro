---
// Component Imports
import { cn } from '../../lib/utils.ts';

export interface Props {
	class?: string;
	side?: 'top' | 'right' | 'bottom' | 'left';
	children: any;
}

const { class: className, side = 'right', children } = Astro.props;
---

<div
	class="fixed inset-0 z-50 flex justify-end hidden"
	id="sheet-overlay"
>
	<div
		class="fixed inset-0 bg-black/80 backdrop-blur-sm transition-opacity duration-300"
		id="sheet-backdrop"
	></div>

<div
	class="relative flex h-full w-full max-w-xs flex-col bg-background shadow-lg transform translate-x-full transition-transform duration-300 ease-in-out"
	id="sheet-content"
>
		<div class="flex items-center justify-between p-4 border-b">
			<span class="text-lg font-semibold">Menu</span>
			<button
				id="close-sheet"
				class="inline-flex items-center justify-center rounded-md p-2 text-muted-foreground hover:bg-accent hover:text-accent-foreground focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2"
			>
				<svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
				</svg>
				<span class="sr-only">Close</span>
			</button>
		</div>
		<div class="flex-1 overflow-auto py-4">
			<slot />
		</div>
	</div>
</div>

<script>
	document.addEventListener('DOMContentLoaded', function() {
		const sheetOverlay = document.getElementById('sheet-overlay');
		const sheetBackdrop = document.getElementById('sheet-backdrop');
		const sheetContent = document.getElementById('sheet-content');
		const closeButton = document.getElementById('close-sheet');

		function closeSheet() {
			if (sheetContent) {
				sheetContent.classList.add('translate-x-full');
				sheetContent.classList.remove('translate-x-0');
			}
			// Delay hiding the overlay to allow animation to complete
			setTimeout(() => {
				if (sheetOverlay) {
					sheetOverlay.classList.add('hidden');
					document.body.style.overflow = '';
				}
			}, 300);
		}

		function openSheet() {
			if (sheetOverlay) {
				sheetOverlay.classList.remove('hidden');
				document.body.style.overflow = 'hidden';
				// Delay adding the translate class to allow overlay to appear first
				setTimeout(() => {
					if (sheetContent) {
						sheetContent.classList.remove('translate-x-full');
						sheetContent.classList.add('translate-x-0');
					}
				}, 10);
			}
		}

		// Close sheet when clicking backdrop
		if (sheetBackdrop) {
			sheetBackdrop.addEventListener('click', closeSheet);
		}

		// Close sheet when clicking close button
		if (closeButton) {
			closeButton.addEventListener('click', closeSheet);
		}

		// Close sheet on escape key
		document.addEventListener('keydown', function(e) {
			if (e.key === 'Escape' && !sheetOverlay?.classList.contains('hidden')) {
				closeSheet();
			}
		});

		// Close sheet when clicking on menu links
		// Add event listener after a short delay to ensure content is rendered
		setTimeout(() => {
			const menuLinks = sheetOverlay?.querySelectorAll('a');
			menuLinks?.forEach(link => {
				link.addEventListener('click', closeSheet);
			});
		}, 100);

		// Make the sheet functions available globally for the menu button
		(window as any).openSheet = openSheet;
		(window as any).closeSheet = closeSheet;
	});
</script>

<style>
	#sheet-overlay.hidden {
		@apply hidden;
	}
</style>
