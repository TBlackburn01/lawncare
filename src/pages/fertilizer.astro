---
// Component Imports
import MainLayout from '../layouts/main.astro';
import QuoteForm from '../components/QuoteForm.astro';

const pageTitle = "Professional Fertilizer Services | Best Lawn Care";
---

<MainLayout content={{ title: pageTitle }}>
	<!-- Hero Section -->
	<section class="relative">
		<div class="aspect-[16/9] w-full">
			<img
				src="/360_F_1558613182_00BMPcg5HipVvhgLdQ9urARNl3huKHrF.webp"
				alt="Professional fertilizer application service"
				class="w-full h-full object-cover"
			/>
			<div class="absolute inset-0 bg-black/40"></div>
			<div class="absolute inset-0 flex items-center justify-center">
				<div class="text-center text-white max-w-4xl mx-auto px-4">
					<h1 class="text-4xl md:text-6xl font-bold mb-6">
						Professional Fertilizer Services
					</h1>
					<p class="text-xl md:text-2xl mb-8 opacity-90">
						Custom fertilizer programs to promote healthy, vibrant green lawns year-round
					</p>
					<div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
						<a
							href="tel:6163714651"
							class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8 py-6 text-lg"
						>
							Call Now: (616) 371-4651
						</a>
						<a
							href="#quote-form"
							class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-input hover:bg-accent hover:text-accent-foreground h-11 px-8 py-6 text-lg"
						>
							Get Quote
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Service Details -->
	<section class="py-16">
		<div class="container mx-auto px-4">
			<div class="grid lg:grid-cols-2 gap-12 items-center mb-16">
				<div>
					<h2 class="text-3xl md:text-4xl font-bold mb-6">Custom Fertilizer Programs</h2>
					<p class="text-lg text-muted-foreground mb-6">
						Our professional fertilizer services are designed to give your lawn the nutrients it needs for optimal health and vibrant growth. We use high-quality, environmentally friendly products tailored to your specific grass type and soil conditions.
					</p>

					<div class="space-y-4">
						<div class="flex items-start gap-3">
							<svg class="w-6 h-6 text-primary mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<div>
								<h3 class="font-semibold mb-1">Soil Analysis</h3>
								<p class="text-muted-foreground">We test your soil to determine the exact nutrients needed for optimal lawn health.</p>
							</div>
						</div>

						<div class="flex items-start gap-3">
							<svg class="w-6 h-6 text-primary mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<div>
								<h3 class="font-semibold mb-1">Custom Blends</h3>
								<p class="text-muted-foreground">Specialized fertilizer formulations based on your lawn's specific requirements and local climate.</p>
							</div>
						</div>

						<div class="flex items-start gap-3">
							<svg class="w-6 h-6 text-primary mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<div>
								<h3 class="font-semibold mb-1">Seasonal Timing</h3>
								<p class="text-muted-foreground">Properly timed applications throughout the year to match your grass's natural growth cycles.</p>
							</div>
						</div>

						<div class="flex items-start gap-3">
							<svg class="w-6 h-6 text-primary mt-1 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<div>
								<h3 class="font-semibold mb-1">Professional Application</h3>
								<p class="text-muted-foreground">Expert application techniques ensure even coverage and maximum effectiveness.</p>
							</div>
						</div>
					</div>
				</div>

				<div class="relative">
					<div class="aspect-[4/3] rounded-lg overflow-hidden">
						<img
							src="/360_F_1323945471_ccNBpnR4tQkfpmXRJQnY8OtfvwHRPZA1.webp"
							alt="Professional fertilizer application equipment"
							class="w-full h-full object-cover"
						/>
					</div>
				</div>
			</div>

			<!-- Benefits Section -->
			<div class="bg-muted/50 rounded-lg p-8 md:p-12">
				<h2 class="text-3xl font-bold text-center mb-8">Benefits of Professional Fertilization</h2>
				<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
					<div class="text-center">
						<div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
							</svg>
						</div>
						<h3 class="font-semibold mb-3">Deeper Root Systems</h3>
						<p class="text-muted-foreground">Proper nutrition leads to stronger, deeper roots that can better withstand drought and stress.</p>
					</div>

					<div class="text-center">
						<div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
							</svg>
						</div>
						<h3 class="font-semibold mb-3">Vibrant Color</h3>
						<p class="text-muted-foreground">Achieve that deep, rich green color that makes your lawn the envy of the neighborhood.</p>
					</div>

					<div class="text-center">
						<div class="w-16 h-16 bg-primary/10 rounded-full flex items-center justify-center mx-auto mb-4">
							<svg class="w-8 h-8 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
							</svg>
						</div>
						<h3 class="font-semibold mb-3">Disease Resistance</h3>
						<p class="text-muted-foreground">Well-nourished lawns are more resistant to diseases, pests, and environmental stressors.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Fertilizer Programs -->
	<section class="py-16 bg-muted/30">
		<div class="container mx-auto px-4">
			<div class="text-center mb-12">
				<h2 class="text-3xl md:text-4xl font-bold mb-4">Fertilizer Programs</h2>
				<p class="text-lg text-muted-foreground max-w-2xl mx-auto">
					Choose from our comprehensive fertilizer programs designed to meet different lawn care needs and budgets.
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
				<div class="bg-background rounded-lg p-8 shadow-sm border">
					<div class="text-center mb-6">
						<h3 class="text-2xl font-bold mb-2">Essential</h3>
						<div class="text-3xl font-bold text-primary mb-2">$45<span class="text-lg text-muted-foreground">/application</span></div>
						<p class="text-muted-foreground">Basic fertilization program</p>
					</div>
					<ul class="space-y-3 mb-6">
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>4 applications per year</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Balanced NPK formula</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Basic soil amendment</span>
						</li>
					</ul>
					<a
						href="tel:6163714651"
						class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-11"
					>
						Call for Quote
					</a>
				</div>

				<div class="bg-background rounded-lg p-8 shadow-sm border border-primary relative">
					<div class="absolute -top-3 left-1/2 transform -translate-x-1/2">
						<span class="bg-primary text-primary-foreground text-sm font-medium px-3 py-1 rounded-full">Most Popular</span>
					</div>
					<div class="text-center mb-6">
						<h3 class="text-2xl font-bold mb-2">Complete</h3>
						<div class="text-3xl font-bold text-primary mb-2">$65<span class="text-lg text-muted-foreground">/application</span></div>
						<p class="text-muted-foreground">Comprehensive nutrition program</p>
					</div>
					<ul class="space-y-3 mb-6">
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Everything in Essential</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>6 applications per year</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Micronutrient package</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>pH balancing</span>
						</li>
					</ul>
					<a
						href="tel:6163714651"
						class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-11"
					>
						Call for Quote
					</a>
				</div>

				<div class="bg-background rounded-lg p-8 shadow-sm border">
					<div class="text-center mb-6">
						<h3 class="text-2xl font-bold mb-2">Premium Plus</h3>
						<div class="text-3xl font-bold text-primary mb-2">$85<span class="text-lg text-muted-foreground">/application</span></div>
						<p class="text-muted-foreground">Maximum nutrition and protection</p>
					</div>
					<ul class="space-y-3 mb-6">
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Everything in Complete</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>8 applications per year</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Organic options available</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Pre-emergent weed control</span>
						</li>
						<li class="flex items-center gap-3">
							<svg class="w-5 h-5 text-primary" viewBox="0 0 24 24" fill="currentColor">
								<path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
							</svg>
							<span>Monthly progress reports</span>
						</li>
					</ul>
					<a
						href="tel:6163714651"
						class="w-full inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-primary text-primary-foreground hover:bg-primary/90 h-11"
					>
						Call for Quote
					</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Process Section -->
	<section class="py-16">
		<div class="container mx-auto px-4">
			<h2 class="text-3xl font-bold text-center mb-12">Our Fertilization Process</h2>
			<div class="grid md:grid-cols-4 gap-8">
				<div class="text-center">
					<div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">1</div>
					<h3 class="font-semibold mb-3">Soil Testing</h3>
					<p class="text-muted-foreground">We analyze your soil to determine current nutrient levels and pH balance.</p>
				</div>

				<div class="text-center">
					<div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">2</div>
					<h3 class="font-semibold mb-3">Custom Planning</h3>
					<p class="text-muted-foreground">We create a personalized fertilization schedule based on your lawn's specific needs.</p>
				</div>

				<div class="text-center">
					<div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">3</div>
					<h3 class="font-semibold mb-3">Professional Application</h3>
					<p class="text-muted-foreground">Our trained technicians apply the fertilizer using professional equipment for even coverage.</p>
				</div>

				<div class="text-center">
					<div class="w-16 h-16 bg-primary text-primary-foreground rounded-full flex items-center justify-center mx-auto mb-4 text-2xl font-bold">4</div>
					<h3 class="font-semibold mb-3">Monitoring & Adjustment</h3>
					<p class="text-muted-foreground">We monitor your lawn's progress and adjust the program as needed for optimal results.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Call to Action -->
	<section class="py-16 bg-primary text-primary-foreground">
		<div class="container mx-auto px-4 text-center">
			<h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Get Started?</h2>
			<p class="text-lg mb-8 opacity-90 max-w-2xl mx-auto">
				Contact us today for a free soil analysis and customized fertilizer program for your lawn.
			</p>
			<div class="flex flex-col sm:flex-row gap-4 justify-center">
				<a
					href="tel:6163714651"
					class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background bg-background text-foreground hover:bg-accent hover:text-accent-foreground h-11 px-8 py-6 text-lg"
				>
					Call: (616) 371-4651
				</a>
				<a
					href="/"
					class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:opacity-50 disabled:pointer-events-none ring-offset-background border border-primary-foreground/20 hover:bg-primary-foreground/10 h-11 px-8 py-6 text-lg"
				>
					Back to Home
				</a>
			</div>
		</div>
	</section>

	<!-- Quote Form -->
	<QuoteForm client:load />
</MainLayout>
